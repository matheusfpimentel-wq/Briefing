# ─── Supabase ───────────────────────────────────────────────
# Encontre em: Supabase > Project Settings > API
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
# Chave service_role (SECRETA — nunca exponha no frontend)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# ─── Resend (e-mail) ────────────────────────────────────────
# Encontre em: resend.com > API Keys
RESEND_API_KEY=re_xxxxxxxxxxxx
# E-mail que recebe a notificação do briefing (o seu)
NOTIFY_EMAIL=seu-email@exemplo.com
# Remetente verificado no Resend (default funciona em testes)
RESEND_FROM=onboarding@resend.dev
